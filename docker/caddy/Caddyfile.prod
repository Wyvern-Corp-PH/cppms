public.{env.DOMAIN} {
	reverse_proxy public-frontend:3000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}

admin.{env.DOMAIN} {
	reverse_proxy admin-frontend:3000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}

pocketbase.{env.DOMAIN} {
	reverse_proxy pocketbase:8090
}
