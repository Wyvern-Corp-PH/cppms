# Local domain (add to hosts: 127.0.0.1 public.cppms.local admin.cppms.local pocketbase.cppms.local)
DOMAIN=cppms.local

# Caddy
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# PocketBase
POCKETBASE_ENCRYPTION_KEY=dev-local-encryption-key-change-me
POCKETBASE_ADMIN_EMAIL=admin@cppms.local
POCKETBASE_ADMIN_PASSWORD=change-me-dev-password
ORIGINS=https://public.cppms.local,https://admin.cppms.local,http://public.cppms.local,http://admin.cppms.local
LOG_LEVEL=info
LOG_STDOUT=1

# Next.js — browser-facing URLs (Caddy + local_certs)
NEXT_PUBLIC_POCKETBASE_URL=https://pocketbase.cppms.local
NEXT_PUBLIC_PUBLIC_URL=https://public.cppms.local
NEXT_PUBLIC_ADMIN_URL=https://admin.cppms.local

# Dev seed (`bun run seed:dev:docker` when stack runs in Docker)

# Semantic release
SEMANTIC_RELEASE_REPOSITORY_URL=https://github.com/bakajieyan/cppms.git
